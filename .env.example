# Database Driver: "sqlite" (default, no network needed) or "postgres"
DB_DRIVER=sqlite

# SQLite (used when DB_DRIVER=sqlite)
SQLITE_DB_PATH=./data/database.sqlite

# PostgreSQL (used when DB_DRIVER=postgres, e.g. for production)
DATABASE_URL=postgresql://username:password@localhost:5432/tkp-people-connect

# JWT
JWT_SECRET=your-jwt-secret-key-min-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-characters-long

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# AWS SES (for email - falls back to console logging if not configured)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
EMAIL_FROM=noreply@tkp-people-connect.com
